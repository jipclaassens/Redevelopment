////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//
// WOZ-waarde per m2 voor NIET-woningen, tbv verwervingskosten in de R-pijplijn van het densification-paper (issue #13):
// loc_woz_nonres_eur_m2 in PerObject_Export; R rekent verwervingskosten niet-woon = Eur/m2 x obj_floor_area_res_m2.
//
// Bron: PBL-notitie 190215 (pbl-woz-per-m2.xls + 190215_{buurt,wijk,gem}_woz.csv): gemiddelde WOZ Eur/m2 per
// regio (CBS-indeling 2017) x bodemgebruiksgroep (BBG 2015): 1=woongebied, 2=voorzieningen (detailhandel/horeca,
// openbare en sociaal-culturele voorzieningen), 3=bedrijfsterreinen, 4=overigen. Peiljaar 2017.
//
// Grid-route (25m): waarde van de cel = regiowaarde van de groep van de dominante BBG-klasse (2017) van die cel,
// met fallback buurt -> wijk -> gemeente waar een regio x groep geen waarneming heeft. Doordat de waarde op de
// LOCATIE ligt (niet aan het VBO hangt), werkt dit ook voor gesloopte objecten en is er geen vintage-koppeling
// met de BAG nodig. Kanttekening (bewust): de groep volgt het bodemgebruik van de locatie, niet de functie van
// het object zelf.
//
// NB: plain mean gebruikt; de dormante voorganger telde ook 1 sd op (mean + sd), dat is hier bewust geschrapt.
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container WOZ : using = "classifications/bbg"
{
	unit<uint8> WOZBbg : NrOfRows = 4
	{
		attribute<string> name : ['woongebied', 'voorzieningen', 'bedrijfsterreinen', 'overigen'];
		attribute<uint8>  EK_rel := id(.) + 1b; // bg2015_groep in de CSV's is 1-based
	}

	unit<uint8> CBSKlasse := classifications/bbg/gg_src
	{
		attribute<WOZBbg> WOZBbg_rel :=
			id(.) == V/woongebied
				? 0[WOZBbg]
				: id(.) == V/detailhandel_en_horeca || id(.) == V/openbare_voorzieningen || id(.) == V/sociaalculturele_voorzieningen
					? 1[WOZBbg]
					: id(.) == V/bedrijfsterreinen
						? 2[WOZBbg]
						: 3[WOZBbg];
	}

	container Y2017 // CBS-gebiedsindeling 2017; peiljaar WOZ 2017
	{
		container Gemeente := T('gem'  , 'GM', /SourceData/RegioIndelingen/impl/CBS/Y2017/Gemeente);
		container Wijk     := T('wijk' , 'WK', /SourceData/RegioIndelingen/impl/CBS/Y2017/Wijk);
		container Buurt    := T('buurt', 'BU', /SourceData/RegioIndelingen/impl/CBS/Y2017/Buurt);

		// per groep: buurtwaarde, waar leeg wijkwaarde, waar leeg gemeentewaarde
		container per_WOZBbg :=
			for_each_nedv(
				WOZBbg/name,
				'MakeDefined(MakeDefined(Buurt/Nul2Undefined/'+WOZBbg/name+', Wijk/Nul2Undefined/'+WOZBbg/name+'), Gemeente/Nul2Undefined/'+WOZBbg/name+')',
				rdc_25m, eur_m2
			);

		// groep van de cel via dominante BBG-klasse 2017 (25m) -> Eur/m2 van de cel
		attribute<eur_m2> per_25m (rdc_25m) := =
			'merge('
				'value(CBSKlasse/WOZBbg_rel[/SourceData/Grondgebruik/bestand_bodem_gebruik/BBG/Dominant/per_25m_modus/J2017], uint16),'
				'eur_m2,'+
				AsItemList('per_WOZBbg/'+WOZBbg/name)+
			')';

		Template T
		{
			//
			parameter<string> SrcRef;
			parameter<string> CodeRef;
			unit<uint32> RegionK;
			//

			unit<uint32> Domain
			:  StorageName = "= '%Redev_DataDir%/Vastgoed/WOZ/190215_'+ SrcRef +'_woz.csv'"
			,  StorageType = "gdal.vect"
			,  StorageReadOnly = "True"
			{
				attribute<string> r2017;
				attribute<string> bg2015_groep;
				attribute<string> wozm2_mean;
				attribute<string> wozm2_sd;
				attribute<string> aantalobjecten;

				attribute<string>  R_CODE     := CodeRef + r2017;
				attribute<RegionK> Region_rel := rjoin(R_CODE, RegionK/code, id(RegionK));
				attribute<WOZBbg>  WOZBbg_rel := rjoin(uint8(bg2015_groep), WOZBbg/EK_rel, id(WOZBbg));

				attribute<eur_m2>  mean       := wozm2_mean[eur_m2];
				attribute<int32>   n          := aantalobjecten[int32];
			}

			attribute<RegionK> per_grid_rel (rdc_25m) := poly2grid(RegionK/geometry, rdc_25m);

			// pivot: een rij per regio x groep -> waarde per regio per groep (regio's zonder rij krijgen sum = 0)
			container per_WOZBbg_regio :=
				for_each_nedv(
					WOZBbg/name,
					'sum(Domain/mean * float64(Domain/WOZBbg_rel == '+string(id(WOZBbg))+'[WOZBbg]), Domain/Region_rel)',
					RegionK, eur_m2
				);

			// naar het grid; 0 (= geen waarneming voor deze regio x groep) wordt undefined zodat de fallback pakt
			container Nul2Undefined :=
				for_each_nedv(
					WOZBbg/name,
					'per_WOZBbg_regio/'+WOZBbg/name+'[per_grid_rel] == 0[eur_m2] ? (0/0)[eur_m2] : per_WOZBbg_regio/'+WOZBbg/name+'[per_grid_rel]',
					rdc_25m, eur_m2
				);
		}
	}
}
