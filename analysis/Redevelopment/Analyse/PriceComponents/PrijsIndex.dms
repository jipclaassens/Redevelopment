// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// Inlezen van de prijsindex voor verschillende woningtypen. inlezen van coefficienten uit prijsindex. Template
// voor het inlezen van de prijsindex voor een bepaald woningtype.
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container PrijsIndex
: Descr = "Inlezen van de prijsindex voor verschillende woningtypen."
{
	parameter<String> Schattingen_StareaRef := 'NL';
	
	// container ReadCoefficients_WP2 := 
		// for_each_ne(
			// Vastgoed/WP2/name
			// , 'T('+string(id(Vastgoed/WP2))+'[Vastgoed/WP2],''WP2'','''','+quote(ModelParameters/NVM_filedate)+')'
		// );
		
	container ReadCoefficients_WP4 := 
		for_each_ne(
			Classifications/BAG/WP4/name
			, 'T('+string(id(Classifications/BAG/WP4))+'[Classifications/BAG/WP4],''WP4'','''','+quote(Parameters/NVM_filedate)+')'
		), Descr = "inlezen van coefficienten uit prijsindex.", URL = "https://github.com/jipclaassens/PriceIndices";
	
	Template T
	: Descr = "Template voor het inlezen van de prijsindex voor een bepaald woningtype."
	{
		//
		parameter<Types_dom> id;
		parameter<String> Types_dom_str; 
		parameter<String> Schattingen_StareaRef0;
		parameter<String> Datum;
		//
		parameter<String> Schattingen_StareaRef := Schattingen_StareaRef0 == '' ? Schattingen_StareaRef0 : '_'+Schattingen_StareaRef0;
		unit<UInt8>       Types_dom := ='Classifications/BAG/'+Types_dom_str;
		parameter<String> WP_name   := =lowercase(Types_dom_str) == lowercase('WP4') ? 'Types_dom/name_english[id]' : 'Types_dom/name[id]';
		
		unit<UInt32> AdminDomain
		:  StorageName = "= '%Redev_DataDir%/Vastgoed/Estimates_'+Datum+'_'+WP_name+'.csv'"
		,  StorageType = "gdal.vect"
		,  StorageReadOnly = "True"
		{
			// Format R-pipeline (PriceIndices, vanaf 20260711): term;estimate;std_error;t_value;p_value;ci_low;ci_high.
			// Termnamen zijn al GeoDMS-conform (constant, bouwperiode_*, trans_year_*, lntt_500k_2024, lntt_ovknoop, uai_2012);
			// referentiecategorieen (bouwperiode_va2002, trans_year_2000) staan erin met estimate 0. Geen hernoem-mapping meer nodig.
			attribute<String> term;
			attribute<String> name := lowercase(term);
		}
	
		container Result := 
			for_each_nedv(
				Classifications/BAG/HouseCharacteristics_src/name
				, 'rjoin(rlookup('+quote(lowercase(Classifications/BAG/HouseCharacteristics_src/name))+', lowercase(AdminDomain/name)), id(AdminDomain), AdminDomain/estimate)[float64]'
				, void
				, float64
			), Descr = "Inlezen van de coëfficiënten voor de prijsindex op basis van de naam van de variabele.";
	}
}